# ─────────────────────────────────────────────
#  LexAI — Environment Variables
#  Copy to backend/.env and fill in your values
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-min-32-chars-change-this

# ── Database (local PostgreSQL) ───────────────
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/lexai

# ── Vector DB (Qdrant Cloud or local) ───────
# Cloud: https://cloud.qdrant.io → cluster URL + API key
# Local: QDRANT_URL=http://localhost:6333 (leave API key empty)
QDRANT_URL=https://your-cluster-id.cloud.qdrant.io
QDRANT_API_KEY=
QDRANT_COLLECTION=lexai_playbooks

# ── AI / Groq ────────────────────────────────
# Get your key at: https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.1-70b-versatile

# ── LangSmith Observability (optional) ───────
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=lexai-production
LANGSMITH_TRACING=false

# ── Auth (RSA key paths) ─────────────────────
# Generate with: openssl genrsa -out keys/private.pem 2048
#                openssl rsa -in keys/private.pem -pubout -out keys/public.pem
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Security ─────────────────────────────────
RISK_APPROVAL_THRESHOLD=80
RATE_LIMIT_PER_MINUTE=100
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=./uploads

# ── CORS ─────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]
ALLOWED_HOSTS=["*"]
