# ─────────────────────────────────────────────
#  LexAI — Environment Variables
#  Copy to .env and fill in your values
# ─────────────────────────────────────────────

# ── App ──────────────────────────────────────
APP_ENV=production
DEBUG=false
SECRET_KEY=your-secret-key-min-32-chars-change-this

# ── Database ─────────────────────────────────
POSTGRES_PASSWORD=change_me_strong_password
DATABASE_URL=postgresql+asyncpg://lexai:change_me_strong_password@postgres:5432/lexai

# ── Vector DB ────────────────────────────────
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=lexai_playbooks

# ── AI / Groq ────────────────────────────────
# Get your key at: https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.1-70b-versatile

# ── LangSmith Observability ──────────────────
# Get your key at: https://smith.langchain.com
LANGSMITH_API_KEY=ls__xxxxxxxxxxxxxxxxxxxxxxxxxxxx
LANGSMITH_PROJECT=lexai-production
LANGSMITH_TRACING=true

# ── Auth (RSA key paths) ─────────────────────
# Generate with: openssl genrsa -out keys/private.pem 2048
#                openssl rsa -in keys/private.pem -pubout -out keys/public.pem
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Security ─────────────────────────────────
RISK_APPROVAL_THRESHOLD=80
RATE_LIMIT_PER_MINUTE=100
MAX_UPLOAD_SIZE_MB=50

# ── CORS ─────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","https://app.lexai.com"]
